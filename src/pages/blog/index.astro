---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { BLOG } from "@consts";

const PART_TITLES: Record<string, string> = {
  "0": "Foundations",
  "1": "Anatomy of a Unit of Compute",
  "2": "GPU Sharing",
  "3": "Job Scheduling",
  "4": "Cluster Sharing",
  "5": "Failure Recovery",
  "6": "Measurement & Economics",
  "7": "Synthesis",
};

// Parse the "N.M" prefix from a title like "1.3 · Splitting One GPU".
const partKey = (title: string) =>
  title.trim().match(/^(\d+)\.(\d+)/) ?? ["", "99", "99"];

const data = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const A = partKey(a.data.title);
    const B = partKey(b.data.title);
    return (
      parseInt(A[1]) - parseInt(B[1]) || parseInt(A[2]) - parseInt(B[2])
    );
  });

const parts: { part: string; posts: typeof data }[] = [];
for (const post of data) {
  const part = partKey(post.data.title)[1];
  let bucket = parts.find((p) => p.part === part);
  if (!bucket) {
    bucket = { part, posts: [] };
    parts.push(bucket);
  }
  bucket.posts.push(post);
}
---

<PageLayout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate space-y-3">
        <div class="font-semibold text-black dark:text-white">
          Blog
        </div>
        <p class="text-sm text-black/60 dark:text-white/60">
          A place to share and bookmark notes on GPU scheduling, capacity planning for AI workloads, and the infrastructure behind large-scale ML.
        </p>
        <p class="text-sm text-black/60 dark:text-white/60">
          I build AI infrastructure — the capacity layer — @AWS, previously @Apple.
        </p>
      </div>
      <div class="space-y-8">
        {parts.map(({ part, posts }) => (
          <section class="animate space-y-4">
            <div class="font-semibold text-black dark:text-white">
              {PART_TITLES[part] ? `Part ${part} — ${PART_TITLES[part]}` : part}
            </div>
            <div>
              <ul class="flex flex-col gap-4">
                {posts.map((post) => (
                  <li>
                    <ArrowCard entry={post} />
                  </li>
                ))}
              </ul>
            </div>
          </section>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>
