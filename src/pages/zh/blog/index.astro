---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { BLOG } from "@consts";

const PART_TITLES: Record<string, string> = {
  "0": "基础",
  "1": "算力单元剖析",
  "2": "GPU 共享",
  "3": "作业调度",
  "4": "集群共享",
  "5": "故障恢复",
  "6": "度量与经济学",
  "7": "综合",
};

const partKey = (title: string) =>
  title.trim().match(/^(\d+)\.(\d+)/) ?? ["", "99", "99"];

const data = (await getCollection("blogZh"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const A = partKey(a.data.title);
    const B = partKey(b.data.title);
    return (
      parseInt(A[1]) - parseInt(B[1]) || parseInt(A[2]) - parseInt(B[2])
    );
  });

const parts: { part: string; posts: typeof data }[] = [];
for (const post of data) {
  const part = partKey(post.data.title)[1];
  let bucket = parts.find((p) => p.part === part);
  if (!bucket) {
    bucket = { part, posts: [] };
    parts.push(bucket);
  }
  bucket.posts.push(post);
}
---

<PageLayout title="博客" description="关于 AI 基础设施、分布式系统和算力调度的文章">
  <Container>
    <div class="space-y-10">
      <div class="animate font-semibold text-black dark:text-white">
        博客文章
      </div>
      <div class="space-y-8">
        {parts.map(({ part, posts }) => (
          <section class="animate space-y-4">
            <div class="font-semibold text-black dark:text-white">
              {PART_TITLES[part] ? `第 ${part} 部分 · ${PART_TITLES[part]}` : part}
            </div>
            <div>
              <ul class="flex flex-col gap-4">
                {posts.map((post) => (
                  <li>
                    <ArrowCard entry={post} href={`/zh/blog/${post.slug}`} />
                  </li>
                ))}
              </ul>
            </div>
          </section>
        ))}
      </div>
    </div>
  </Container>
</PageLayout>
